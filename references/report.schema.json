{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weeklyviz.local/report.schema.json",
  "title": "WeeklyViz Report Model",
  "type": "object",
  "required": ["metadata", "template", "summary", "sources"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["report_id", "title", "period"],
      "properties": {
        "report_id": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "subtitle": {"type": "string"},
        "locale": {"type": "string", "default": "zh-CN"},
        "source_label": {"type": "string"},
        "synthetic": {"type": "boolean"},
        "generated_at": {"type": "string"},
        "updated_at": {"type": "string"},
        "period": {
          "type": "object",
          "required": ["label"],
          "properties": {
            "label": {"type": "string", "minLength": 1},
            "start": {"type": "string"},
            "end": {"type": "string"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "template": {
      "type": "string"
    },
    "theme": {
      "type": "object",
      "properties": {
        "primary": {"$ref": "#/$defs/color"},
        "accent": {"$ref": "#/$defs/color"},
        "background": {"$ref": "#/$defs/color"},
        "surface": {"$ref": "#/$defs/color"},
        "text": {"$ref": "#/$defs/color"},
        "muted": {"$ref": "#/$defs/color"}
      },
      "additionalProperties": false
    },
    "presentation": {
      "type": "object",
      "properties": {
        "density": {"enum": ["compact", "balanced", "spacious"]},
        "layout": {"enum": ["dashboard", "newsletter", "kanban", "operating-review"]},
        "layout_order": {
          "type": "array",
          "items": {"type": "string"}
        },
        "section_layout": {"enum": ["cards", "grid", "list", "table", "kanban"]},
        "source_display": {"enum": ["summary", "expanded"]},
        "show_toc": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": ["headline", "body"],
      "properties": {
        "headline": {"type": "string"},
        "body": {"type": "string"},
        "highlights": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    },
    "kpis": {
      "type": "array",
      "items": {"$ref": "#/$defs/kpi"}
    },
    "progress": {
      "type": "array",
      "items": {"$ref": "#/$defs/progress"}
    },
    "charts": {
      "type": "array",
      "items": {"$ref": "#/$defs/chart"}
    },
    "sections": {
      "type": "array",
      "items": {"$ref": "#/$defs/section"}
    },
    "risks": {
      "type": "array",
      "items": {"$ref": "#/$defs/actionItem"}
    },
    "next_actions": {
      "type": "array",
      "items": {"$ref": "#/$defs/actionItem"}
    },
    "sources": {
      "type": "array",
      "items": {"$ref": "#/$defs/source"}
    },
    "metrics": {
      "type": "array",
      "items": {"$ref": "#/$defs/metric"}
    },
    "okrs": {
      "type": "array",
      "items": {"$ref": "#/$defs/okr"}
    }
  },
  "additionalProperties": true,
  "$defs": {
    "color": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$"
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "traceable": {
      "type": "object",
      "required": ["source_refs"],
      "properties": {
        "source_refs": {"$ref": "#/$defs/sourceRefs"},
        "derived": {"type": "boolean"},
        "formula": {"type": "string"}
      }
    },
    "kpi": {
      "allOf": [
        {"$ref": "#/$defs/traceable"},
        {
          "type": "object",
          "required": ["id", "label", "value"],
          "properties": {
            "id": {"type": "string"},
            "label": {"type": "string"},
            "value": {"type": ["number", "string"]},
            "display": {"type": "string"},
            "unit": {"type": "string"},
            "note": {"type": "string"},
            "details": {
              "type": "array",
              "items": {"$ref": "#/$defs/labelValue"}
            },
            "trend": {
              "type": "object",
              "properties": {
                "value": {"type": ["number", "string"]},
                "label": {"type": "string"},
                "direction": {"enum": ["up", "down", "flat", "neutral"]}
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },
    "progress": {
      "allOf": [
        {"$ref": "#/$defs/traceable"},
        {
          "type": "object",
          "required": ["id", "label", "current", "target"],
          "properties": {
            "id": {"type": "string"},
            "label": {"type": "string"},
            "current": {"type": "number"},
            "target": {"type": "number", "exclusiveMinimum": 0},
            "unit": {"type": "string"},
            "status": {"enum": ["on-track", "watch", "risk", "complete"]}
          }
        }
      ]
    },
    "series": {
      "type": "object",
      "required": ["name", "values"],
      "properties": {
        "name": {"type": "string"},
        "values": {
          "type": "array",
          "items": {
            "oneOf": [
              {"type": "number"},
              {
                "type": "array",
                "minItems": 2,
                "items": {"type": "number"}
              },
              {
                "type": "object",
                "required": ["name", "value"],
                "properties": {
                  "name": {"type": "string"},
                  "value": {"type": "number"}
                }
              }
            ]
          }
        }
      },
      "additionalProperties": true
    },
    "chart": {
      "allOf": [
        {"$ref": "#/$defs/traceable"},
        {
          "type": "object",
          "required": ["id", "type", "title", "question", "unit", "insight", "series"],
          "properties": {
            "id": {"type": "string"},
            "type": {
              "enum": [
                "line", "area", "bar", "horizontal-bar", "grouped-bar",
                "stacked-bar", "donut", "pie", "waterfall", "funnel",
                "scatter", "heatmap", "timeline", "table"
              ]
            },
            "title": {"type": "string"},
            "question": {"type": "string"},
            "unit": {"type": "string"},
            "insight": {"type": "string"},
            "insight_points": {
              "type": "array",
              "items": {"type": "string"}
            },
            "labels": {
              "type": "array",
              "items": {"type": "string"}
            },
            "series": {
              "type": "array",
              "minItems": 1,
              "items": {"$ref": "#/$defs/series"}
            }
          }
        }
      ]
    },
    "section": {
      "type": "object",
      "required": ["id", "title", "items"],
      "properties": {
        "id": {"type": "string"},
        "title": {"type": "string"},
        "summary": {"type": "string"},
        "layout": {"enum": ["cards", "grid", "list", "table", "kanban"]},
        "source_refs": {
          "type": "array",
          "items": {"type": "string"}
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title", "body"],
            "properties": {
              "title": {"type": "string"},
              "body": {"type": "string"},
              "status": {"enum": ["complete", "on-track", "watch", "risk", "planned", "neutral"]},
              "owner": {"type": "string"},
              "meta": {"type": "string"},
              "outcome": {"type": "string"},
              "next": {"type": "string"},
              "metrics": {
                "type": "array",
                "items": {"$ref": "#/$defs/labelValue"}
              },
              "source_refs": {
                "type": "array",
                "items": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "labelValue": {
      "type": "object",
      "required": ["label", "value"],
      "properties": {
        "label": {"type": "string"},
        "value": {"type": ["string", "number"]}
      },
      "additionalProperties": false
    },
    "actionItem": {
      "type": "object",
      "required": ["title", "body"],
      "properties": {
        "title": {"type": "string"},
        "body": {"type": "string"},
        "owner": {"type": "string"},
        "due": {"type": "string"},
        "severity": {"enum": ["low", "medium", "high", "critical"]},
        "status": {"enum": ["planned", "on-track", "watch", "risk", "complete"]},
        "source_refs": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "source": {
      "type": "object",
      "required": ["id", "label", "type", "location"],
      "properties": {
        "id": {"type": "string"},
        "label": {"type": "string"},
        "type": {"type": "string"},
        "location": {"type": "string"},
        "note": {"type": "string"}
      },
      "additionalProperties": true
    },
    "metric": {
      "allOf": [
        {"$ref": "#/$defs/traceable"},
        {
          "type": "object",
          "required": ["id", "name", "value", "unit", "scope", "time_grain", "aggregation"],
          "properties": {
            "id": {"type": "string"},
            "name": {"type": "string"},
            "value": {"type": ["number", "string"]},
            "unit": {"enum": ["percent", "currency", "integer", "number", "ratio"]},
            "scope": {
              "type": "array",
              "items": {"type": "string"}
            },
            "time_grain": {"enum": ["day", "week", "month", "quarter", "year"]},
            "aggregation": {"enum": ["sum", "average", "ratio", "count", "distinct_count", "none"]},
            "numerator": {"type": "string"},
            "denominator": {"type": "string"},
            "comparison": {
              "type": "object",
              "properties": {
                "previous": {"type": ["number", "string"]}
              },
              "additionalProperties": true
            },
            "target": {
              "type": "object",
              "properties": {
                "value": {"type": ["number", "string"]},
                "period": {"type": "string"},
                "direction": {"enum": ["higher-is-better", "lower-is-better", "range"]},
                "range_min": {"type": "number"},
                "range_max": {"type": "number"},
                "source": {"type": "string"},
                "confidence": {"enum": ["high", "medium", "low"]}
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "okr": {
      "allOf": [
        {"$ref": "#/$defs/traceable"},
        {
          "type": "object",
          "required": ["id", "type", "label"],
          "properties": {
            "id": {"type": "string"},
            "type": {"enum": ["objective", "key-result", "plan", "requirement"]},
            "parent_id": {"type": "string"},
            "label": {"type": "string"},
            "owner": {"type": "string"},
            "stage": {"enum": ["待启动", "设计", "开发", "验收", "上线", "暂缓", "planned", "design", "dev", "qa", "release", "deferred"]},
            "health": {"enum": ["正常", "关注", "风险", "阻塞", "on-track", "watch", "risk", "blocked"]},
            "priority": {"type": ["string", "number"]},
            "due": {"type": "string"},
            "blocked_by": {"type": "string"},
            "dependencies": {
              "type": "array",
              "items": {"type": "string"}
            },
            "evidence": {"type": "string"},
            "next_milestone": {"type": "string"},
            "current": {"type": "number"},
            "target": {"type": "number"},
            "unit": {"type": "string"}
          },
          "additionalProperties": true
        }
      ]
    }
  }
}
